# Copy to .env and `source .env` before running heavy scripts locally.

# Keep threads in check on laptops/CI
export OMP_NUM_THREADS=1
export OPENBLAS_NUM_THREADS=1
export MKL_NUM_THREADS=1
export NUMEXPR_NUM_THREADS=1

# Optional: choose CPU torch explicitly if you have multiple envs
# export PIP_EXTRA_INDEX_URL=https://download.pytorch.org/whl/cpu

# Make the src/ package importable without install
export PYTHONPATH=$(pwd)/src:${PYTHONPATH}
